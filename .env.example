# Copy to .env and fill in ONLY when you intend to go live.
# .env is gitignored. Never commit real keys.

# --- Polymarket (CLOB) ---
# Wallet private key used to sign orders. Use a dedicated, low-balance wallet.
POLYMARKET_PRIVATE_KEY=
# Polygon address of that wallet.
POLYMARKET_FUNDER_ADDRESS=
# API creds derived from the wallet (py-clob-client can generate these).
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# CLOB host (default mainnet)
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
